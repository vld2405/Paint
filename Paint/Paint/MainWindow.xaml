<Window x:Class="Paint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paint - Transformări Omogene" Height="500" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#f0f0f0" Padding="10" BorderBrush="Gray" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="LEGENDA" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#333"/>

                <TextBlock Text="• Desenare:" FontWeight="SemiBold"/>
                <TextBlock Text="Click stânga simplu" Margin="5,0,0,10" FontSize="11"/>

                <TextBlock Text="• Translație:" FontWeight="SemiBold"/>
                <TextBlock Text="CTRL + Click Stânga (Drag)" Margin="5,0,0,10" FontSize="11"/>

                <TextBlock Text="• Scalare:" FontWeight="SemiBold"/>
                <TextBlock Text="CTRL + Scroll Up/Down" Margin="5,0,0,10" FontSize="11"/>

                <TextBlock Text="• Rotație:" FontWeight="SemiBold"/>
                <TextBlock Text="Butonul 'Rotește'" Margin="5,0,0,10" FontSize="11"/>
                
                <TextBlock Text="• Finalizare:" FontWeight="SemiBold"/>
                <TextBlock Text="Double Click stânga" Margin="5,0,0,10" FontSize="11"/>

                <TextBlock Text="• Rotație Interactivă:" FontWeight="SemiBold"/>
                <TextBlock Text="ALT + Click Stânga (Drag)" Margin="5,0,0,10" FontSize="11"/>

                <Separator Margin="0,10"/>

                <Button Content="Simetrie Dreaptă" Click="BtnSimetrieDreapta_Click" Margin="0,2"/>
                <Button Content="Simetrie Origine" Click="BtnSimetrie_Click" Margin="0,2"/>
                <Button Content="Resetare Completă" Click="BtnReset_Click" Margin="0,20" Background="#ffebee"/>
            </StackPanel>
        </Border>

        <Canvas x:Name="MainCanvas" Grid.Column="1" Background="White" 
                MouseDown="MainCanvas_MouseDown" 
                MouseMove="MainCanvas_MouseMove"
                MouseWheel="MainCanvas_MouseWheel"
                ClipToBounds="True"/>
    </Grid>
</Window>