<Window x:Class="ParametricCurves.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tema 2 - Curbe Parametrice" Height="500" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#f4f4f4" Padding="15" BorderBrush="LightGray" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="SETĂRI CURBĂ" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Alege Curba:" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbCurves" SelectedIndex="0" SelectionChanged="CmbCurves_SelectionChanged" Margin="0,5,0,15">
                    <ComboBoxItem Content="1. Elipsă (x=cos u, y=2sin u)"/>
                    <ComboBoxItem Content="2. Spirală 2D (x=u cos u, y=u sin u)"/>
                    <ComboBoxItem Content="3. Parabolă (x=u, y=u²+1)"/>
                </ComboBox>

                <TextBlock Text="Început interval (a):" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtA" Text="0" Margin="0,5,0,10" Padding="2"/>

                <TextBlock Text="Sfârșit interval (b):" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtB" Text="6.28" Margin="0,5,0,10" Padding="2"/>

                <TextBlock Text="Rezoluție (n):" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtN" Text="100" Margin="0,5,0,20" Padding="2" ToolTip="Numărul de puncte generate pe curbă"/>

                <Button Content="Desenează Curba" Click="BtnDraw_Click" Padding="5" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Canvas x:Name="DrawCanvas" Grid.Column="1" Background="White" SizeChanged="DrawCanvas_SizeChanged" ClipToBounds="True"/>
    </Grid>
</Window>