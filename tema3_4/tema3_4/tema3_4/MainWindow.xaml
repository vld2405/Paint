<Window x:Class="tema3_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tema 3/4 - Interpolare Lagrange și Newton" Height="600" Width="800">
    <Grid>
        <Canvas x:Name="MainCanvas" Background="White"
                MouseLeftButtonDown="MainCanvas_MouseLeftButtonDown"
                MouseRightButtonDown="MainCanvas_MouseRightButtonDown"
                MouseMove="MainCanvas_MouseMove"
                MouseLeftButtonUp="MainCanvas_MouseLeftButtonUp"/>

        <StackPanel Orientation="Vertical" Margin="10" IsHitTestVisible="True" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="InstructionsText" 
                       Text="Click Stânga: Adaugă puncte (strict de la stânga la dreapta).&#x0a;Click Dreapta: Finalizează și desenează polinomul." 
                       Foreground="DimGray" FontWeight="SemiBold" Margin="0,0,0,10" IsHitTestVisible="False"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Metodă interpolare: " VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox x:Name="CmbMetoda" Width="120" SelectedIndex="0" SelectionChanged="CmbMetoda_SelectionChanged">
                    <ComboBoxItem Content="Lagrange"/>
                    <ComboBoxItem Content="Newton"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>