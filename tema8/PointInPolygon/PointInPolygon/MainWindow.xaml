<Window x:Class="PointInPolygon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tema 8 - Punct în Poligon" Height="600" Width="800">
    <Grid>
        <Canvas x:Name="MainCanvas" Background="White" 
                MouseDown="MainCanvas_MouseDown" 
                MouseMove="MainCanvas_MouseMove"
                ClipToBounds="True"/>

        <StackPanel Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" IsHitTestVisible="False">
            <TextBlock Text="Etapa I: Click stânga pt. puncte, Double-click pt. finalizare poligon." FontWeight="Bold" Foreground="DimGray"/>
            <TextBlock Text="Etapa II: CTRL + Drag pt. translație (recolorează automat)." FontWeight="Bold" Foreground="DimGray"/>
            <TextBlock x:Name="StatusText" Text="Status: Desenare poligon" Foreground="Blue" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>